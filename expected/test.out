--
-- test.sql
--
-- safesession.blocked_commands is set in safesession.conf at server startup.
-- It cannot be changed at runtime (PGC_POSTMASTER).
--
-- Setup: create test objects before activating safesession
create table t(i int);
create function f(IN p int, OUT i int) returns int as $$
begin
  insert into t(i) values (f.p) returning t.i into f.i;
end$$
language plpgsql;
-- Activate safesession: from now on the session is read-only
LOAD 'safesession';
-- Show the blocked_commands setting (set at startup)
SHOW safesession.blocked_commands;
         safesession.blocked_commands          
-----------------------------------------------
 vacuum, analyze, cluster, reindex, checkpoint
(1 row)

-- SELECTs still work
select * from t;
 i 
---
(0 rows)

-- DML is blocked
insert into t values (1);
ERROR:  cannot execute INSERT in a read-only transaction
-- Volatile function that attempts a write is blocked
select f(1);
ERROR:  cannot execute INSERT in a read-only transaction
CONTEXT:  SQL statement "insert into t(i) values (f.p) returning t.i"
PL/pgSQL function f(integer) line 3 at SQL statement
-- DDL is blocked
CREATE TABLE t2(i int);
ERROR:  cannot execute CREATE TABLE in a read-only transaction
-- DO block with DML is blocked
DO $$ BEGIN INSERT INTO t VALUES (99); END $$;
ERROR:  cannot execute INSERT in a read-only transaction
CONTEXT:  SQL statement "INSERT INTO t VALUES (99)"
PL/pgSQL function inline_code_block line 1 at SQL statement
select * from t;
 i 
---
(0 rows)

-- Modifying CTE is blocked
with inserted as (insert into t values(3) returning 3) select * from inserted;
ERROR:  cannot execute SELECT in a read-only transaction
-- Large object creation is blocked
SELECT lo_create(0);
 lo_create 
-----------
     16389
(1 row)

-- Maintenance commands are blocked per safesession.blocked_commands
VACUUM t;
ERROR:  VACUUM is blocked by safesession
ANALYZE t;
ERROR:  ANALYZE is blocked by safesession
CLUSTER t;
ERROR:  CLUSTER is blocked by safesession
REINDEX TABLE t;
ERROR:  REINDEX is blocked by safesession
CHECKPOINT;
ERROR:  CHECKPOINT is blocked by safesession
-- Cannot change at runtime
SET safesession.blocked_commands = '';
ERROR:  parameter "safesession.blocked_commands" cannot be changed now
